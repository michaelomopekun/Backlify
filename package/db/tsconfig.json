{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "types": [
            "node"
        ],
        // "baseUrl": ".",
        // "paths": {
        //     "@backlify/shared": [
        //         "../shared"
        //     ],
        //     "@backlify/shared/*": [
        //         "../shared/*"
        //     ]
        // }
    },
    "include": [
        "**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ],
    "extends": "../../tsconfig.base.json"
}